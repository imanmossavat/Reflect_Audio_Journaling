{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LatentWorldState",
  "type": "object",
  "required": ["user_profile", "entities", "story_arcs", "projects", "latent_facts"],
  "additionalProperties": false,
  "properties": {
    "user_profile": {
      "type": "object",
      "required": ["name", "age", "occupation"],
      "properties": {
        "name":       { "type": "string" },
        "age":        { "type": "integer" },
        "occupation": { "type": "string" }
      }
    },
    "entities": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "required": ["entity_id", "name", "type", "domains"],
        "additionalProperties": true,
        "properties": {
          "entity_id": { "type": "string" },
          "name":      { "type": "string" },
          "type":      { "type": "string" },
          "domains":   { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "story_arcs": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["arc_id", "title", "status"],
        "additionalProperties": true,
        "properties": {
          "arc_id": { "type": "string" },
          "title":  { "type": "string" },
          "status": { "type": "string", "enum": ["active", "dormant", "stalled", "resolved"] }
        }
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["project_id", "title", "status"],
        "additionalProperties": true,
        "properties": {
          "project_id": { "type": "string" },
          "title":      { "type": "string" },
          "status":     { "type": "string" }
        }
      }
    },
    "latent_facts": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["fact_id", "description"],
        "additionalProperties": true,
        "properties": {
          "fact_id":     { "type": "string" },
          "description": { "type": "string" }
        }
      }
    }
  }
}
